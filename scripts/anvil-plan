#!/usr/bin/env bash
# anvil-plan — extract conversation from aider, send to Claude for detailed planning
# Run from within aider: /run anvil-plan

set -uo pipefail

# Optional positional arg: spec file. If given, use it instead of aider history.
SPEC_FILE="${1:-}"

if [ -n "$SPEC_FILE" ]; then
    if [ ! -f "$SPEC_FILE" ]; then
        echo "Spec file not found: $SPEC_FILE"
        exit 1
    fi
    CONVERSATION="SPEC FILE ($SPEC_FILE):
$(cat "$SPEC_FILE")"
else
    HISTORY=".aider.chat.history.md"
    if [ ! -f "$HISTORY" ]; then
        echo "No conversation history found."
        echo "Chat with your LLM first, then run: /run anvil-plan"
        echo "Or pass a spec file: anvil-plan path/to/spec.md"
        exit 1
    fi

    # Extract the conversation — user messages (####) and assistant responses
    # Skip aider metadata lines (starting with >)
    CONVERSATION=$(awk '
        /^#### / { sub(/^#### /, ""); print "USER: " $0; next }
        /^> / { next }
        /^# aider/ { next }
        { print }
    ' "$HISTORY" | tail -200)

    if [ -z "$CONVERSATION" ]; then
        echo "No conversation content found in history."
        exit 1
    fi
fi

mkdir -p .anvil

PLAN_PROMPT="You are a senior software architect producing an implementation plan.

Your job: produce a detailed implementation plan with numbered tasks.

Each task must have:
- A clear title
- What files to create or modify
- Step-by-step instructions (specific enough for a coding agent)
- Acceptance criteria

Go straight to the task list — no preamble, no questions.

Output the plan in markdown. Start each task with ### Task N: Title

---

${CONVERSATION}"

# Try Hercules first — free. Fall back to Claude if unavailable.
echo "Planning with local LLM..."
RESULT=$(~/tools/hercules-generate.sh "$PLAN_PROMPT" 2>/dev/null)
HERCULES_EXIT=$?

if [ $HERCULES_EXIT -ne 0 ] || [ -z "$RESULT" ] || ! echo "$RESULT" | grep -q "### Task"; then
    echo "Local LLM unavailable or produced no tasks — falling back to Claude..."
    RESULT=$(claude -p "$PLAN_PROMPT" --allowedTools "Read,Grep,Glob" --output-format text --max-turns 5 2>&1)
else
    echo "Plan generated by local LLM."
fi

echo "$RESULT"

echo "$RESULT" > .anvil/plan.md
echo ""
echo "────────────────────────────────────"
echo "Plan saved to .anvil/plan.md"

if echo "$RESULT" | grep -qi "^QUESTIONS:"; then
    echo ""
    echo "Claude has questions. Answer them with:"
    echo "  /run anvil-plan-answers \"your answers here\""
else
    echo "Plan ready. Review it, then start building with:"
    echo "  /run anvil-build"
fi
