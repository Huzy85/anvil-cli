#!/usr/bin/env bash
# anvil-test-suite-resume — run tests 12-24 and append to existing results
# Usage: anvil-test-suite-resume [/path/to/results.md]
#
# Requires: aider, anvil-review, a running LLM endpoint
# Run from outside a Claude Code session, or it will auto-escape the cgroup.

set -uo pipefail

# ── Cgroup escape ───────────────────────────────────────────────────────────
if grep -q "claude-code.slice" /proc/$$/cgroup 2>/dev/null; then
    exec systemd-run --user --scope -p TasksMax=2000 -p CPUQuota=400% -- bash "$0" "$@"
fi

# ── Config ──────────────────────────────────────────────────────────────────
ANVIL_ENV="${HOME}/.anvil.env"
[ -f "$ANVIL_ENV" ] && source "$ANVIL_ENV"

TEST_MODEL="${ANVIL_TEST_MODEL:-openai/auto}"
TEST_API_BASE="${ANVIL_TEST_API_BASE:-http://localhost:8080/v1}"
TEST_API_KEY="${ANVIL_TEST_API_KEY:-not-needed}"

LOG="${1:-${HOME}/anvil-test-results-batch2.md}"
TOTAL=13
PASS=0
FAIL=0
ERRORS=""

echo "# Anvil Test Results — Batch 2 (Tests 12-24) — $(date)" > "$LOG"
echo "" >> "$LOG"

# ── run_test ─────────────────────────────────────────────────────────────────
run_test() {
    local NUM="$1"
    local NAME="$2"
    local PROMPT="$3"
    local WORKDIR="/tmp/anvil-t${NUM}"
    local LOGFILE="/tmp/anvil-output-${NUM}.log"
    local PROMPTFILE="/tmp/anvil-prompt-${NUM}.md"

    echo "=== Test $NUM: $NAME ==="
    echo "### Test $NUM: $NAME" >> "$LOG"
    echo "" >> "$LOG"

    rm -rf "$WORKDIR"
    mkdir -p "$WORKDIR"
    pushd "$WORKDIR" > /dev/null

    git init -q
    git config user.name "Anvil Test"
    git config user.email "test@anvil.local"
    echo "# test project" > README.md
    git add README.md
    git commit -q -m "init"

    echo "$PROMPT" > "$PROMPTFILE"

    OPENBLAS_NUM_THREADS=1 timeout 300 aider \
        --message-file "$PROMPTFILE" \
        --yes-always \
        --no-analytics \
        --no-show-model-warnings \
        --no-show-release-notes \
        --no-check-update \
        --no-browser \
        --auto-lint \
        --lint-cmd "python: anvil-review" \
        --lint-cmd "javascript: anvil-review" \
        --lint-cmd "typescript: anvil-review" \
        --lint-cmd "go: anvil-review" \
        --lint-cmd "rust: anvil-review" \
        --model "$TEST_MODEL" \
        --openai-api-base "$TEST_API_BASE" \
        --openai-api-key "$TEST_API_KEY" \
        < /dev/null > "$LOGFILE" 2>&1

    AIDER_EXIT=$?

    FILES=$(find . \( -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.go" -o -name "*.rs" \) -not -path "./.git/*" -not -path "./target/*" 2>/dev/null | sort)

    REVIEW_COUNT=$(grep -c "Review" "$LOGFILE" 2>/dev/null || true)
    APPROVED_COUNT=$(grep -c "APPROVED" "$LOGFILE" 2>/dev/null || true)
    REJECTED_COUNT=$(grep -c "REJECTED" "$LOGFILE" 2>/dev/null || true)
    FIX_COUNT=$(grep -c "Escalation" "$LOGFILE" 2>/dev/null || true)
    FIXED_COUNT=$(grep -c "FIXED by" "$LOGFILE" 2>/dev/null || true)

    REVIEW_COUNT="${REVIEW_COUNT:-0}"
    APPROVED_COUNT="${APPROVED_COUNT:-0}"
    REJECTED_COUNT="${REJECTED_COUNT:-0}"
    FIX_COUNT="${FIX_COUNT:-0}"
    FIXED_COUNT="${FIXED_COUNT:-0}"

    TEST_RESULT="no tests"
    TEST_OUTPUT=""
    if compgen -G "test_*.py" > /dev/null 2>&1; then
        TEST_OUTPUT=$(python3 -m pytest -x -q 2>&1)
        TEST_EXIT=$?
        TEST_RESULT=$([ $TEST_EXIT -eq 0 ] && echo "PASS" || echo "FAIL")
    elif compgen -G "*.test.js" > /dev/null 2>&1; then
        TEST_OUTPUT=$(node *.test.js 2>&1)
        TEST_EXIT=$?
        TEST_RESULT=$([ $TEST_EXIT -eq 0 ] && echo "PASS" || echo "FAIL")
    elif compgen -G "*.test.ts" > /dev/null 2>&1; then
        TEST_OUTPUT=$(tsc --strict *.ts 2>&1 && node *.test.js 2>&1)
        TEST_EXIT=$?
        TEST_RESULT=$([ $TEST_EXIT -eq 0 ] && echo "PASS" || echo "FAIL")
    elif compgen -G "*_test.go" > /dev/null 2>&1; then
        [ ! -f "go.mod" ] && go mod init testmod 2>/dev/null
        TEST_OUTPUT=$(go test -v 2>&1)
        TEST_EXIT=$?
        TEST_RESULT=$([ $TEST_EXIT -eq 0 ] && echo "PASS" || echo "FAIL")
    elif [ -f "Cargo.toml" ]; then
        TEST_OUTPUT=$(cargo test 2>&1)
        TEST_EXIT=$?
        TEST_RESULT=$([ $TEST_EXIT -eq 0 ] && echo "PASS" || echo "FAIL")
    fi

    popd > /dev/null

    echo "- Files: $(echo "$FILES" | tr '\n' ' ')" >> "$LOG"
    echo "- Aider exit: $AIDER_EXIT" >> "$LOG"
    echo "- Reviews: $REVIEW_COUNT (approved: $APPROVED_COUNT, rejected: $REJECTED_COUNT, escalations: $FIX_COUNT, fixed: $FIXED_COUNT)" >> "$LOG"
    echo "- Tests: $TEST_RESULT" >> "$LOG"

    if [ "$AIDER_EXIT" = "124" ]; then
        echo "- ERROR: Timed out after 300s" >> "$LOG"
        FAIL=$((FAIL + 1))
        ERRORS="${ERRORS}\n  $NUM. $NAME — timeout"
    elif grep -q "can't start new thread\|RuntimeError" "$LOGFILE" 2>/dev/null && [ -z "$FILES" ]; then
        echo "- ERROR: Thread limit hit — run outside claude-code.slice" >> "$LOG"
        FAIL=$((FAIL + 1))
        ERRORS="${ERRORS}\n  $NUM. $NAME — thread exhaustion"
    elif [ "$TEST_RESULT" = "FAIL" ]; then
        echo "- Test output:" >> "$LOG"
        echo '```' >> "$LOG"
        echo "$TEST_OUTPUT" | tail -20 >> "$LOG"
        echo '```' >> "$LOG"
        FAIL=$((FAIL + 1))
        ERRORS="${ERRORS}\n  $NUM. $NAME — tests failed"
    elif [ "$REVIEW_COUNT" = "0" ]; then
        echo "- WARNING: No review ran" >> "$LOG"
        FAIL=$((FAIL + 1))
        ERRORS="${ERRORS}\n  $NUM. $NAME — no review"
    else
        PASS=$((PASS + 1))
    fi

    if [ "$REJECTED_COUNT" != "0" ]; then
        echo "- Rejection details:" >> "$LOG"
        echo '```' >> "$LOG"
        grep -A5 "REJECTED" "$LOGFILE" | head -30 >> "$LOG"
        echo '```' >> "$LOG"
    fi

    echo "" >> "$LOG"
    echo "  Reviews: $REVIEW_COUNT | Approved: $APPROVED_COUNT | Rejected: $REJECTED_COUNT | Escalations: $FIX_COUNT | Fixed: $FIXED_COUNT | Tests: $TEST_RESULT"
    echo ""
}

# ── run_test_with_seed ────────────────────────────────────────────────────────
run_test_with_seed() {
    local NUM="$1"
    local NAME="$2"
    local SEED_SCRIPT="$3"
    local PROMPT="$4"
    local WORKDIR="/tmp/anvil-t${NUM}"
    local LOGFILE="/tmp/anvil-output-${NUM}.log"
    local PROMPTFILE="/tmp/anvil-prompt-${NUM}.md"

    echo "=== Test $NUM: $NAME ==="
    echo "### Test $NUM: $NAME" >> "$LOG"
    echo "" >> "$LOG"

    rm -rf "$WORKDIR"
    mkdir -p "$WORKDIR"
    pushd "$WORKDIR" > /dev/null

    git init -q
    git config user.name "Anvil Test"
    git config user.email "test@anvil.local"

    eval "$SEED_SCRIPT"

    git add -A
    git commit -q -m "seed: initial code"

    echo "$PROMPT" > "$PROMPTFILE"

    OPENBLAS_NUM_THREADS=1 timeout 300 aider \
        --message-file "$PROMPTFILE" \
        --yes-always \
        --no-analytics \
        --no-show-model-warnings \
        --no-show-release-notes \
        --no-check-update \
        --no-browser \
        --auto-lint \
        --lint-cmd "python: anvil-review" \
        --lint-cmd "javascript: anvil-review" \
        --lint-cmd "typescript: anvil-review" \
        --lint-cmd "go: anvil-review" \
        --lint-cmd "rust: anvil-review" \
        --model "$TEST_MODEL" \
        --openai-api-base "$TEST_API_BASE" \
        --openai-api-key "$TEST_API_KEY" \
        < /dev/null > "$LOGFILE" 2>&1

    AIDER_EXIT=$?

    FILES=$(find . \( -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.go" -o -name "*.rs" \) -not -path "./.git/*" -not -path "./target/*" 2>/dev/null | sort)

