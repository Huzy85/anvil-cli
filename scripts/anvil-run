#!/usr/bin/env bash
# anvil-run — full pipeline: spec → plan → build
# Chains anvil-plan and anvil-build into a single command.
#
# Usage:
#   anvil-run spec.md   Plan from spec file, then build
#   anvil-run           Build from existing .anvil/plan.md (skip planning)

set -uo pipefail

ANVIL_ENV="${HOME}/.anvil.env"
[ -f "$ANVIL_ENV" ] && source "$ANVIL_ENV"

SPEC_FILE="${1:-}"
PLAN_FILE=".anvil/plan.md"

if [ -z "$SPEC_FILE" ] && [ ! -f "$PLAN_FILE" ]; then
    echo ""
    echo "  No spec file given and no plan at $PLAN_FILE"
    echo "  ─────────────────────────────────────────"
    echo "  Usage:"
    echo "    anvil-run spec.md   Plan from spec, then build"
    echo "    anvil-run           Build from existing plan"
    echo ""
    exit 1
fi

if [ -n "$SPEC_FILE" ]; then
    if [ ! -f "$SPEC_FILE" ]; then
        echo "  Spec file not found: $SPEC_FILE"
        exit 1
    fi
    echo ""
    echo "  ── Anvil Run — Plan + Build ─────────────"
    echo "  Spec: $SPEC_FILE"
    echo "  Step 1/2: Generating plan with Claude..."
    echo ""
    if ! anvil-plan "$SPEC_FILE"; then
        echo ""
        echo "  Planning failed. Stopping before build."
        exit 1
    fi

    if grep -qi "^QUESTIONS:" "$PLAN_FILE" 2>/dev/null; then
        echo ""
        echo "  Claude has questions in the plan — answer them before building:"
        echo "    /run anvil plan-answers \"your answers here\""
        echo ""
        exit 0
    fi
fi

echo ""
echo "  Step 2/2: Building from $PLAN_FILE..."
echo ""
exec anvil-build
