#!/usr/bin/env bash
# anvil — launch aider with local LLM + Claude Code review
# https://github.com/Huzy85/anvil

set -euo pipefail

# Load config if exists
ANVIL_ENV="${HOME}/.anvil.env"
[ -f "$ANVIL_ENV" ] && source "$ANVIL_ENV"

# Prevent OpenBLAS thread explosion on machines running llama.cpp
export OPENBLAS_NUM_THREADS="${OPENBLAS_NUM_THREADS:-1}"

# Subcommands — used from inside aider as /run anvil <cmd>
case "${1:-}" in
    help)
        echo ""
        echo "  Anvil Commands"
        echo "  ─────────────────────────────────────────"
        echo ""
        echo "  Just type and chat — your LLM codes, reviewer checks each edit."
        echo ""
        echo "  /run plan             Send conversation to Claude for a task plan"
        echo "  /run plan-answers     Answer Claude's planning questions"
        echo "  /run build            Auto-feed plan tasks one by one"
        echo "  /run run [spec.md]    Plan from spec then build (full pipeline)"
        echo "  /run tokens           Show token usage for this project"
        echo "  /run help             This help message"
        echo ""
        echo "  Config files:"
        echo "    ~/.aider.conf.yml       Model and endpoint settings"
        echo "    ~/.anvil.env            Reviewer settings"
        echo ""
        exit 0
        ;;
    plan)
        shift
        exec anvil-plan "$@"
        ;;
    plan-answers)
        shift
        exec anvil-plan-answers "$@"
        ;;
    build)
        shift
        exec anvil-build "$@"
        ;;
    run)
        shift
        exec anvil-run "$@"
        ;;
    tokens)
        USAGE_LOG="${ANVIL_USAGE_LOG:-.anvil/usage.log}"
        if [ ! -f "$USAGE_LOG" ]; then
            echo "  No usage log found at $USAGE_LOG"
            exit 0
        fi
        TOTAL=$(awk -F'\t' '{sum+=$3} END {print sum+0}' "$USAGE_LOG")
        REVIEWS=$(grep -c "review" "$USAGE_LOG" 2>/dev/null || true)
        ESCALATIONS=$(grep -c "escalation" "$USAGE_LOG" 2>/dev/null || true)
        APPROVED=$(grep -c "approved" "$USAGE_LOG" 2>/dev/null || true)
        REJECTED=$(grep -c "rejected" "$USAGE_LOG" 2>/dev/null || true)
        echo ""
        echo "  Anvil Token Usage"
        echo "  ─────────────────────────────────────────"
        echo "  Total tokens sent : ~${TOTAL}"
        echo "  Reviews           : ${REVIEWS} (${APPROVED} approved, ${REJECTED} rejected)"
        echo "  Escalations       : ${ESCALATIONS}"
        echo "  Log               : ${USAGE_LOG}"
        echo ""
        exit 0
        ;;
esac

# No subcommand — launch aider
if [[ "$*" != *"--message"* ]] && [[ "$*" != *"--message-file"* ]]; then
    echo ""
    echo "  Anvil v0.1.0 — Local LLM codes. Claude reviews."
    echo "  ─────────────────────────────────────────"
    echo "  /run plan       Claude plans your idea"
    echo "  /run build      Auto-build from plan"
    echo "  /run run        Plan from spec then build"
    echo "  /run help       All commands"
    echo ""
fi

exec aider "$@"
