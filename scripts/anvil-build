#!/usr/bin/env python3
"""anvil-build — automated build loop.

Parses tasks from .anvil/plan.md, feeds each to aider (Hercules writes code).
Single Claude review at the end runs tests and fixes any issues found.

Run from within aider: /run anvil-build
Or standalone: anvil-build
"""

import glob
import os
import re
import subprocess
import sys
import argparse
import tempfile


def parse_args():
    parser = argparse.ArgumentParser(description="Anvil automated build loop")
    parser.add_argument("--dry-run", action="store_true",
                        help="Show tasks without executing them")
    parser.add_argument("--skip-review", action="store_true",
                        help="Skip the final Claude review")
    return parser.parse_args()


def parse_plan(plan_path):
    """Extract overview and tasks from the plan markdown."""
    with open(plan_path) as f:
        content = f.read()

    parts = re.split(r'(### Task \d+:)', content)
    overview = parts[0].strip() if parts else ""

    tasks = []
    task_splits = re.split(r'### Task \d+:\s*', content)
    titles = re.findall(r'### Task \d+:\s*(.+)', content)

    for i, (title, body) in enumerate(zip(titles, task_splits[1:]), 1):
        tasks.append({
            "id": i,
            "title": title.strip(),
            "body": body.strip(),
        })
    return overview, tasks


def build_with_message_file(overview, tasks):
    """Drive aider via --message-file. No per-task reviews — single review at end."""
    total = len(tasks)
    accepted = 0
    failed = 0

    for task in tasks:
        print(f"\n{'=' * 60}")
        print(f"[Task {task['id']}/{total}] {task['title']}")
        print(f"{'=' * 60}\n")

        # Extract filenames mentioned in the task so we can be explicit upfront
        files_mentioned = re.findall(
            r'`([^`]+\.(?:py|js|ts|jsx|tsx|go|rs|sh|yaml|yml|json))`',
            task["body"]
        )
        unique_files = list(dict.fromkeys(files_mentioned))  # dedupe, preserve order
        files_str = ", ".join(unique_files) if unique_files else "the files described below"

        # Direct, short message — no big context block that triggers planning mode
        message = f"""Write the complete file contents for: {files_str}

Do not ask for permission. Do not describe what you will do. Just write the code.

Task {task['id']}: {task['title']}

{task['body']}
"""

        with tempfile.NamedTemporaryFile(mode="w", suffix=".md", delete=False) as f:
            f.write(message)
            msg_file = f.name

        sub_env = os.environ.copy()

        try:
            result = subprocess.run(
                [
                    "aider",
                    "--message-file", msg_file,
                    "--yes-always",
                    "--no-analytics",
                    "--no-show-model-warnings",
                    "--no-show-release-notes",
                    "--no-check-update",
                    "--no-browser",
                    "--no-auto-lint",
                ],
                timeout=600,
                env=sub_env,
            )
            if result.returncode == 0:
                accepted += 1
                print(f"\n✓ Task {task['id']} complete")
            else:
                failed += 1
                print(f"\n✗ Task {task['id']} exited with code {result.returncode}")
        except subprocess.TimeoutExpired:
            failed += 1
            print(f"\n✗ Task {task['id']} timed out after 600s")
        finally:
            os.unlink(msg_file)

    print(f"\n{'=' * 60}")
    print(f"Build complete: {accepted} accepted, {failed} failed out of {total}")
    print(f"{'=' * 60}")

    return accepted, failed


def run_final_review(overview):
    """Single Claude review: run tests first.
    If tests pass: cheap confirmation (no file upload).
    If tests fail: send files + errors, let Claude fix directly.
    """
    print(f"\n{'=' * 60}")
    print("Final review — running tests...")
    print(f"{'=' * 60}\n")

    # Run pytest
    test_proc = subprocess.run(
        ["pytest", "-q", "--tb=short"],
        capture_output=True, text=True, timeout=120
    )
    tests_passed = test_proc.returncode == 0
    test_output = (test_proc.stdout + test_proc.stderr).strip()

    print(test_output[:500] if test_output else "(no test output)")

    reviewer = os.environ.get("ANVIL_REVIEWER", "claude -p")

    if tests_passed:
        # Happy path: tests passed — cheap confirmation, no file upload needed
        prompt = f"{test_output}\n\nAll tests passed. Reply APPROVED."
        tools = "Read,Glob"
        max_turns = "3"
    else:
        # Tests failed — send files so Claude can fix
        source_files = sorted(
            f for f in glob.glob("*.py") + glob.glob("*.js") + glob.glob("*.ts")
            if not f.startswith(".") and "/.git/" not in f
        )
        file_blocks = []
        for fname in source_files:
            try:
                with open(fname) as fp:
                    content = fp.read()
                ext = fname.rsplit(".", 1)[-1]
                file_blocks.append(f"### {fname}\n```{ext}\n{content}\n```")
            except OSError:
                pass
        files_text = "\n\n".join(file_blocks) if file_blocks else "(no source files found)"

        prompt = f"""Tests failed. Fix the code so all tests pass.

Test output:
```
{test_output}
```

Source files:
{files_text}

Use Edit/Write to fix the bugs, then run pytest to confirm. Reply APPROVED once all tests pass.
"""
        tools = "Read,Edit,Write,Bash,Glob,Grep"
        max_turns = "15"

    if reviewer == "claude -p":
        result = subprocess.run(
            ["claude", "-p", prompt,
             "--allowedTools", tools,
             "--output-format", "text",
             "--max-turns", max_turns],
            capture_output=True, text=True, timeout=300,
            env=os.environ.copy(),
        )
        output = result.stdout
    else:
        output = "APPROVED" if tests_passed else "REJECTED — tests failed"

    if "APPROVED" in output.upper():
        print("\n✓ Final review: APPROVED")
        return True
    else:
        print("\n✗ Final review: issues found")
        print(output[:1000])
        return False


def main():
    args = parse_args()
    plan_path = ".anvil/plan.md"
    if not os.path.exists(plan_path):
        print("No plan found at .anvil/plan.md")
        print("Run anvil-plan first.")
        sys.exit(1)

    overview, tasks = parse_plan(plan_path)
    if not tasks:
        print("No tasks found in plan. Check .anvil/plan.md format.")
        print("Expected: ### Task N: Title")
        sys.exit(1)

    print(f"Anvil Build — {len(tasks)} tasks from plan")
    print(f"Coder: aider + local LLM (Hercules)")
    print(f"Review: single Claude pass at end")
    print()

    for t in tasks:
        print(f"  {t['id']}. {t['title']}")

    if args.dry_run:
        print()
        print("Dry run — tasks listed, nothing executed.")
        return

    print()
    confirm = input("Start building? [Y/n] ").strip().lower()
    if confirm and confirm != "y":
        print("Aborted.")
        sys.exit(0)

    accepted, failed = build_with_message_file(overview, tasks)

    if not args.skip_review:
        run_final_review(overview)


if __name__ == "__main__":
    main()
