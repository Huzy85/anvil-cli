#!/usr/bin/env python3
"""anvil-build — automated build loop.

Parses tasks from .anvil/plan.md, feeds each to aider with full project
context so the LLM knows how each task fits into the bigger picture.
Claude reviews automatically after each edit via --lint-cmd.

Run from within aider: /run anvil-build
Or standalone: anvil-build
"""

import os
import re
import subprocess
import sys
import tempfile


def parse_plan(plan_path):
    """Extract overview and tasks from the plan markdown."""
    with open(plan_path) as f:
        content = f.read()

    # Everything before the first ### Task is the overview
    parts = re.split(r'(### Task \d+:)', content)
    overview = parts[0].strip() if parts else ""

    # Extract tasks
    tasks = []
    task_splits = re.split(r'### Task \d+:\s*', content)
    titles = re.findall(r'### Task \d+:\s*(.+)', content)

    for i, (title, body) in enumerate(zip(titles, task_splits[1:]), 1):
        tasks.append({
            "id": i,
            "title": title.strip(),
            "body": body.strip(),
        })
    return overview, tasks


def build_context(overview, tasks, current_task_id, completed):
    """Build a context block that tells the LLM where this task fits."""
    lines = []

    lines.append("=" * 60)
    lines.append("PROJECT CONTEXT — Read this before coding.")
    lines.append("=" * 60)
    lines.append("")

    # Plan overview (goal, architecture, tech stack)
    if overview:
        # Take first ~30 lines of overview — enough for goal + architecture
        overview_lines = overview.split("\n")[:30]
        lines.append("## Project Overview")
        lines.append("")
        lines.extend(overview_lines)
        lines.append("")

    # What's been completed so far
    if completed:
        lines.append("## Completed Tasks")
        lines.append("")
        for t in completed:
            lines.append(f"  ✓ Task {t['id']}: {t['title']}")
        lines.append("")

    # What files exist now
    existing = []
    for ext in ["*.py", "*.js", "*.ts", "*.jsx", "*.tsx", "*.go", "*.rs",
                "*.html", "*.css", "*.yaml", "*.yml", "*.json", "*.sh"]:
        import glob
        existing.extend(glob.glob(f"**/{ext}", recursive=True))
    existing = sorted(set(f for f in existing if not f.startswith(".git/")))

    if existing:
        lines.append("## Existing Files")
        lines.append("")
        for f in existing[:30]:
            lines.append(f"  - {f}")
        if len(existing) > 30:
            lines.append(f"  ... and {len(existing) - 30} more")
        lines.append("")

    # What's coming next (so the LLM doesn't build things that later tasks handle)
    remaining = [t for t in tasks if t["id"] > current_task_id]
    if remaining:
        lines.append("## Upcoming Tasks (do NOT implement these now)")
        lines.append("")
        for t in remaining[:5]:
            lines.append(f"  - Task {t['id']}: {t['title']}")
        lines.append("")

    lines.append("=" * 60)
    lines.append("")

    return "\n".join(lines)


def build_review_context(overview, tasks, current_task_id, completed):
    """Write a context file for Claude's review to read."""
    ctx_path = ".anvil/review-context.md"
    os.makedirs(".anvil", exist_ok=True)

    lines = []
    lines.append("# Anvil Review Context")
    lines.append("")
    lines.append(f"Currently reviewing: Task {current_task_id}")
    lines.append("")

    if overview:
        overview_lines = overview.split("\n")[:20]
        lines.append("## Project Goal")
        lines.extend(overview_lines)
        lines.append("")

    if completed:
        lines.append("## Already Completed")
        for t in completed:
            lines.append(f"- Task {t['id']}: {t['title']}")
        lines.append("")

    current = next((t for t in tasks if t["id"] == current_task_id), None)
    if current:
        lines.append("## Current Task Requirements")
        lines.append(f"### Task {current['id']}: {current['title']}")
        lines.append(current["body"][:2000])
        lines.append("")

    with open(ctx_path, "w") as f:
        f.write("\n".join(lines))

    return ctx_path


def build_with_message_file(overview, tasks):
    """Drive aider via --message-file for each task with full context."""
    total = len(tasks)
    accepted = 0
    failed = 0
    completed = []

    for task in tasks:
        print(f"\n{'=' * 60}")
        print(f"[Task {task['id']}/{total}] {task['title']}")
        print(f"{'=' * 60}\n")

        # Build context for the coding LLM
        context = build_context(overview, tasks, task["id"], completed)

        # Build context file for Claude's review
        build_review_context(overview, tasks, task["id"], completed)

        # Compose the full message: context + task
        message = f"""{context}

## YOUR TASK

Task {task['id']}: {task['title']}

{task['body']}

IMPORTANT:
- Follow the task requirements exactly.
- Use the same function signatures, class names, and file names as specified.
- Check existing files before creating new ones — don't duplicate what's already built.
- If other tasks created interfaces you depend on, match them exactly.
"""

        with tempfile.NamedTemporaryFile(mode="w", suffix=".md", delete=False) as f:
            f.write(message)
            msg_file = f.name

        try:
            result = subprocess.run(
                [
                    "aider",
                    "--message-file", msg_file,
                    "--yes-always",
                    "--no-analytics",
                    "--no-show-model-warnings",
                    "--no-show-release-notes",
                    "--no-check-update",
                    "--no-browser",
                    "--auto-lint",
                    "--lint-cmd", "python: anvil-review",
                    "--lint-cmd", "javascript: anvil-review",
                    "--lint-cmd", "typescript: anvil-review",
                ],
                timeout=600,
            )
            if result.returncode == 0:
                accepted += 1
                completed.append(task)
                print(f"\n✓ Task {task['id']} complete")
            else:
                failed += 1
                # Still track as completed for context (files may exist)
                completed.append(task)
                print(f"\n✗ Task {task['id']} exited with code {result.returncode}")
        except subprocess.TimeoutExpired:
            failed += 1
            completed.append(task)
            print(f"\n✗ Task {task['id']} timed out after 600s")
        finally:
            os.unlink(msg_file)

    # Clean up review context
    try:
        os.unlink(".anvil/review-context.md")
    except OSError:
        pass

    print(f"\n{'=' * 60}")
    print(f"Build complete: {accepted} accepted, {failed} failed out of {total}")
    print(f"{'=' * 60}")


def main():
    plan_path = ".anvil/plan.md"
    if not os.path.exists(plan_path):
        print("No plan found at .anvil/plan.md")
        print("Run anvil-plan first.")
        sys.exit(1)

    overview, tasks = parse_plan(plan_path)
    if not tasks:
        print("No tasks found in plan. Check .anvil/plan.md format.")
        print("Expected: ### Task N: Title")
        sys.exit(1)

    print(f"Anvil Build — {len(tasks)} tasks from plan")
    print(f"Coder: aider + local LLM")
    print(f"Reviewer: anvil-review (auto after each edit)")
    print()

    for t in tasks:
        print(f"  {t['id']}. {t['title']}")

    print()
    confirm = input("Start building? [Y/n] ").strip().lower()
    if confirm and confirm != "y":
        print("Aborted.")
        sys.exit(0)

    build_with_message_file(overview, tasks)


if __name__ == "__main__":
    main()
