#!/usr/bin/env bash
# anvil-review — aider --lint-cmd hook that sends diffs to a reviewer
# Called by aider after every file edit. Exit 0 = approved, non-zero = rejected.
#
# Three tiers:
#   1-2 rejections: reviewer checks code, gives feedback, LLM retries
#   3rd rejection:  if Claude — fixes code directly. Otherwise — stops, tells user.

set -uo pipefail

# Save any env vars set on the command line before sourcing the config file
_SAVED_REVIEWER="${ANVIL_REVIEWER:-}"
_SAVED_URL="${ANVIL_REVIEWER_URL:-}"
_SAVED_MODEL="${ANVIL_REVIEWER_MODEL:-}"
_SAVED_KEY="${ANVIL_REVIEWER_API_KEY:-}"

ANVIL_ENV="${HOME}/.anvil.env"
[ -f "$ANVIL_ENV" ] && source "$ANVIL_ENV"

# Command-line env vars override the config file
[ -n "$_SAVED_REVIEWER" ] && ANVIL_REVIEWER="$_SAVED_REVIEWER"
[ -n "$_SAVED_URL" ] && ANVIL_REVIEWER_URL="$_SAVED_URL"
[ -n "$_SAVED_MODEL" ] && ANVIL_REVIEWER_MODEL="$_SAVED_MODEL"
[ -n "$_SAVED_KEY" ] && ANVIL_REVIEWER_API_KEY="$_SAVED_KEY"

REVIEWER="${ANVIL_REVIEWER:-claude -p}"
MAX_DIFF_CHARS="${ANVIL_MAX_DIFF_CHARS:-40000}"
MAX_RETRIES="${ANVIL_MAX_RETRIES:-2}"
REVIEW_TIMEOUT="${ANVIL_REVIEW_TIMEOUT:-90}"
ESCALATION_TIMEOUT="${ANVIL_ESCALATION_TIMEOUT:-120}"
REVIEW_MAX_TURNS="${ANVIL_REVIEW_MAX_TURNS:-6}"

# ── Usage tracking ─────────────────────────────────
USAGE_LOG="${ANVIL_USAGE_LOG:-.anvil/usage.log}"
log_usage() {
    local TYPE="$1"    # review | escalation
    local CHARS="$2"   # chars sent to reviewer
    local RESULT="$3"  # approved | rejected | fixed | timeout | error
    mkdir -p "$(dirname "$USAGE_LOG")"
    echo "$(date +%s)	${TYPE}	${CHARS}	${RESULT}	${REVIEWER}" >> "$USAGE_LOG"
}

FILES="$@"
[ -z "$FILES" ] && exit 0

# ── Rejection counter ──────────────────────────────
# Track per-file rejection count so we know when to escalate
COUNTER_DIR="/tmp/anvil-review-counts"
mkdir -p "$COUNTER_DIR"

# Create a stable key from the sorted file list
FILE_KEY=$(echo "$FILES" | tr ' ' '\n' | sort | md5sum | cut -d' ' -f1)
COUNTER_FILE="${COUNTER_DIR}/${FILE_KEY}"
TOTAL_FILE="${COUNTER_DIR}/${FILE_KEY}.total"

REJECTION_COUNT=0
[ -f "$COUNTER_FILE" ] && REJECTION_COUNT=$(cat "$COUNTER_FILE")

TOTAL_REVIEWS=0
[ -f "$TOTAL_FILE" ] && TOTAL_REVIEWS=$(cat "$TOTAL_FILE")
echo $((TOTAL_REVIEWS + 1)) > "$TOTAL_FILE"

# Hard cap: after MAX_TOTAL total reviews, force escalation
MAX_TOTAL="${ANVIL_MAX_TOTAL_REVIEWS:-3}"
if [ "$TOTAL_REVIEWS" -ge "$MAX_TOTAL" ]; then
    REJECTION_COUNT=$MAX_RETRIES  # force escalation
fi

# ── Build diff ─────────────────────────────────────
DIFF=""
for f in $FILES; do
    if git ls-files --error-unmatch "$f" &>/dev/null; then
        FILE_DIFF=$(git diff HEAD -- "$f" 2>/dev/null)
        [ -z "$FILE_DIFF" ] && FILE_DIFF=$(git diff HEAD~1 -- "$f" 2>/dev/null)
    else
        FILE_DIFF="--- /dev/null
+++ b/$f
$(sed 's/^/+/' "$f")"
    fi
    [ -n "$FILE_DIFF" ] && DIFF="${DIFF}${FILE_DIFF}\n"
done

[ -z "$DIFF" ] && exit 0

# ── Compress diff before sending ───────────────────
# Strip ANSI escape codes, collapse runs of blank lines, remove trailing whitespace
DIFF=$(printf '%b' "$DIFF" \
    | sed 's/\x1b\[[0-9;]*m//g' \
    | sed 's/[[:space:]]*$//' \
    | cat -s)

# ── Load project context if available ─────────────
REVIEW_CONTEXT=""
if [ -f ".anvil/review-context.md" ]; then
    REVIEW_CONTEXT=$(cat ".anvil/review-context.md")
fi

# Truncate huge diffs
DIFF_LEN=${#DIFF}
if [ "$DIFF_LEN" -gt "$MAX_DIFF_CHARS" ]; then
    DIFF="${DIFF:0:$MAX_DIFF_CHARS}

[diff truncated — ${DIFF_LEN} chars total, showing first ${MAX_DIFF_CHARS}]"
fi

# ── Helper: check if result looks like an error ───
check_result_error() {
    local RESULT="$1"
    local EXIT_CODE="$2"
    if [ "$EXIT_CODE" -eq 124 ]; then
        echo "  TIMEOUT: Reviewer did not respond within ${REVIEW_TIMEOUT}s"
        echo "  Code was NOT reviewed. Check the changes manually."
        echo "  ────────────────────────────────────────────"
        log_usage "review" "${#PROMPT}" "timeout"
        exit 1
    fi
    if echo "$RESULT" | grep -qi "Reached max turns"; then
        echo "  WARNING: Reviewer hit turn limit without concluding — review incomplete"
        echo "  Code was NOT reviewed. Check the changes manually."
        echo "  ────────────────────────────────────────────"
        log_usage "review" "$PROMPT_TOKENS" "max_turns"
        exit 1
    fi
    if echo "$RESULT" | grep -qi "rate.limit\|overloaded\|529\|503\|too many requests"; then
        echo "  RATE LIMITED: Reviewer is busy"
        echo "  Code was NOT reviewed. Check the changes manually."
        echo "  ────────────────────────────────────────────"
        log_usage "review" "${#PROMPT}" "error"
        exit 1
    fi
    if echo "$RESULT" | grep -qi "Review error:\|connection refused\|Connection refused"; then
        echo "  ERROR: Reviewer is unreachable"
        echo "  $RESULT"
        echo "  Code was NOT reviewed. Check the changes manually."
        echo "  ────────────────────────────────────────────"
        log_usage "review" "${#PROMPT}" "error"
        exit 1
    fi
}

# ── Escalation after max retries ──────────────────
if [ "$REJECTION_COUNT" -ge "$MAX_RETRIES" ]; then
    echo ""
    echo "  ── Escalation (after $REJECTION_COUNT rejections) ──"
    echo "  Files: $FILES"

    # Only Claude Code CLI can fix code directly (it has file editing tools)
    if [[ "$REVIEWER" == "claude -p"* ]]; then
        echo "  Claude is fixing the code directly..."

        FIX_PROMPT="The following code has been written by a local LLM and rejected $REJECTION_COUNT times during review. The LLM could not fix it.
${REVIEW_CONTEXT:+
Project Context:
${REVIEW_CONTEXT}
}
Read the files, find the bugs, and fix them directly using the Edit tool. Focus on:
- Runtime errors and wrong logic
- Wrong mock patch targets (must patch where imported, not where defined)
- Tests that don't actually test what they claim
- Missing function calls, wrong assertions

Fix the code so all tests pass. Be minimal — only fix bugs, don't refactor.

Files to fix: $FILES

Current diff:
${DIFF}"

        FIX_RESULT=$(timeout "$ESCALATION_TIMEOUT" claude -p "$FIX_PROMPT" --allowedTools "Read,Grep,Glob,Edit,Write,Bash" --output-format text --max-turns 10 2>&1)
        FIX_EXIT=$?
        if [ $FIX_EXIT -eq 124 ]; then
            echo "  TIMEOUT: Claude did not respond within ${ESCALATION_TIMEOUT}s"
            echo "  Code was NOT fixed. Check the changes manually."
            echo "  ────────────────────────────────────────────"
            log_usage "escalation" "${#FIX_PROMPT}" "timeout"
            exit 1
        elif echo "$FIX_RESULT" | grep -qi "rate.limit\|overloaded\|529\|503"; then
            echo "  RATE LIMITED: Claude is busy"
            echo "  Code was NOT fixed. Check the changes manually."
            echo "  ────────────────────────────────────────────"
            log_usage "escalation" "${#FIX_PROMPT}" "error"
            exit 1
        fi
        echo "$FIX_RESULT" | tail -5
        echo "  FIXED by Claude"
        echo "  ────────────────────────────────────────────"
        echo ""
        log_usage "escalation" "${#FIX_PROMPT}" "fixed"
        # Reset counters
        rm -f "$COUNTER_FILE" "$TOTAL_FILE"
        exit 0
    else
        # Non-Claude reviewers can't fix code — tell the user
        echo "  Reviewer rejected this code $REJECTION_COUNT times but cannot fix it directly."
        echo "  (Only Claude Code CLI supports auto-fix escalation.)"
        echo ""
        echo "  Options:"
        echo "    1. Fix the code manually and retry"
        echo "    2. Switch to Claude Code CLI: set ANVIL_REVIEWER=\"claude -p\" in ~/.anvil.env"
        echo "    3. Reset the counter and continue: rm /tmp/anvil-review-counts/${FILE_KEY}*"
        echo "  ────────────────────────────────────────────"
        log_usage "escalation" "0" "no_fixer"
        exit 1
    fi
fi

# ── Normal review ──────────────────────────────────
echo ""
echo "  ── Review [$((REJECTION_COUNT + 1))/${MAX_RETRIES}] ──────────────"
echo "  Files: $FILES"
echo "  Reviewing..."

PROMPT="Review this code change in two passes.

PASS 1 — Read the diff for obvious bugs:
- Runtime errors, wrong logic, security issues
- Wrong mock patch targets (must patch where used, not where defined)
- Missing function calls (e.g. test sets up data but never calls the method being tested)

PASS 2 — Read the actual files to double-check:
- Do the tests actually test what they claim? Trace the logic.
- Are mock return values consistent with how the code uses them?
- Would this code actually work if you ran it?

REJECT only for real bugs — things that would cause wrong results or crashes.
DO NOT REJECT for style, deprecation warnings, naming, or type hints.

If the code works correctly: say APPROVED on its own line.
If there are real bugs: say REJECTED on its own line, then for EACH bug provide:
- What is wrong (one sentence)
- The exact fix: show the corrected code the LLM should write

The LLM fixing this code is not very smart. Give it exact code to copy, not descriptions.
${REVIEW_CONTEXT:+
Project Context:
${REVIEW_CONTEXT}
}
Diff:
${DIFF}"

# Estimate tokens in prompt (4 chars ≈ 1 token)
PROMPT_TOKENS=$(( (${#PROMPT} + 3) / 4 ))

# Run the reviewer with timeout protection
if [[ "$REVIEWER" == "claude -p"* ]]; then
    RESULT=$(timeout "$REVIEW_TIMEOUT" claude -p "$PROMPT" --allowedTools "Read,Grep,Glob" --output-format text --max-turns "$REVIEW_MAX_TURNS" 2>&1)
    REVIEWER_EXIT=$?
elif [[ "$REVIEWER" == "anvil-review-api" ]]; then
    RESULT=$(timeout "$REVIEW_TIMEOUT" anvil-review-api $FILES 2>&1)
    REVIEWER_EXIT=$?
elif [[ "$REVIEWER" == "anvil-review-local" ]]; then
    RESULT=$(timeout "$REVIEW_TIMEOUT" anvil-review-local $FILES 2>&1)
    REVIEWER_EXIT=$?
else
    RESULT=$(timeout "$REVIEW_TIMEOUT" $REVIEWER $FILES 2>&1)
    REVIEWER_EXIT=$?
fi

# Check for timeout, rate-limit, or connection errors
check_result_error "$RESULT" "$REVIEWER_EXIT"

if echo "$RESULT" | grep -qi "APPROVED"; then
    echo "  APPROVED (~${PROMPT_TOKENS} tokens)"
    echo "  ────────────────────────────────────────────"
    echo ""
    log_usage "review" "$PROMPT_TOKENS" "approved"
    # Reset counters on approval
    rm -f "$COUNTER_FILE" "$TOTAL_FILE"
    exit 0
else
    # Increment rejection counter
    echo $((REJECTION_COUNT + 1)) > "$COUNTER_FILE"
    echo "  REJECTED ($((REJECTION_COUNT + 1))/${MAX_RETRIES} before escalation) (~${PROMPT_TOKENS} tokens)"
    echo ""
    echo "$RESULT"
    echo ""
    echo "  ────────────────────────────────────────────"
    echo ""
    log_usage "review" "$PROMPT_TOKENS" "rejected"
    exit 1
fi
