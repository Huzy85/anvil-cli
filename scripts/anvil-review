#!/usr/bin/env bash
# anvil-review — aider --lint-cmd hook that sends diffs to a reviewer
# Called by aider after every file edit. Exit 0 = approved, non-zero = rejected.

set -uo pipefail

ANVIL_ENV="${HOME}/.anvil.env"
[ -f "$ANVIL_ENV" ] && source "$ANVIL_ENV"

REVIEWER="${ANVIL_REVIEWER:-claude -p}"
MAX_DIFF_CHARS="${ANVIL_MAX_DIFF_CHARS:-40000}"

FILES="$@"
[ -z "$FILES" ] && exit 0

# Build diff — handle tracked, staged, and new untracked files
DIFF=""
for f in $FILES; do
    if git ls-files --error-unmatch "$f" &>/dev/null; then
        # Tracked file — get diff vs HEAD
        FILE_DIFF=$(git diff HEAD -- "$f" 2>/dev/null)
        [ -z "$FILE_DIFF" ] && FILE_DIFF=$(git diff HEAD~1 -- "$f" 2>/dev/null)
    else
        # New untracked file — show full content as diff
        FILE_DIFF="--- /dev/null
+++ b/$f
$(sed 's/^/+/' "$f")"
    fi
    [ -n "$FILE_DIFF" ] && DIFF="${DIFF}${FILE_DIFF}\n"
done

[ -z "$DIFF" ] && exit 0

# Truncate huge diffs
DIFF_LEN=${#DIFF}
if [ "$DIFF_LEN" -gt "$MAX_DIFF_CHARS" ]; then
    DIFF="${DIFF:0:$MAX_DIFF_CHARS}

[diff truncated — ${DIFF_LEN} chars total, showing first ${MAX_DIFF_CHARS}]"
fi

echo ""
echo "  ── Claude Review ──────────────────────────"
echo "  Files: $FILES"
echo "  Reviewing..."

PROMPT="Review this code change in two passes.

PASS 1 — Read the diff for obvious bugs:
- Runtime errors, wrong logic, security issues
- Wrong mock patch targets (must patch where used, not where defined)
- Missing function calls (e.g. test sets up data but never calls the method being tested)

PASS 2 — Read the actual files to double-check:
- Do the tests actually test what they claim? Trace the logic.
- Are mock return values consistent with how the code uses them?
- Would this code actually work if you ran it?

REJECT only for real bugs — things that would cause wrong results or crashes.
DO NOT REJECT for style, deprecation warnings, naming, or type hints.

If the code works correctly: say APPROVED on its own line.
If there are real bugs: say REJECTED on its own line, then list ONLY the bugs (one line each, be specific).

Diff:
${DIFF}"

# Allow Claude to read the actual files for pass 2
ALLOWED_TOOLS="Read,Grep,Glob"

if [[ "$REVIEWER" == "claude -p"* ]]; then
    RESULT=$(claude -p "$PROMPT" --allowedTools "$ALLOWED_TOOLS" --output-format text --max-turns 3 2>&1)
elif [[ "$REVIEWER" == "anvil-review-api" ]]; then
    RESULT=$(anvil-review-api $FILES 2>&1)
elif [[ "$REVIEWER" == "anvil-review-local" ]]; then
    RESULT=$(anvil-review-local $FILES 2>&1)
else
    RESULT=$($REVIEWER $FILES 2>&1)
fi

if echo "$RESULT" | grep -qi "APPROVED"; then
    echo "  APPROVED"
    echo "  ────────────────────────────────────────────"
    echo ""
    exit 0
else
    echo "  REJECTED"
    echo ""
    echo "$RESULT"
    echo ""
    echo "  ────────────────────────────────────────────"
    echo ""
    exit 1
fi
