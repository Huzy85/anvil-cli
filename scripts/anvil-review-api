#!/usr/bin/env bash
# anvil-review-api — review code via any OpenAI-compatible API
# Used when ANVIL_REVIEWER="anvil-review-api" in ~/.anvil.env

set -uo pipefail

ANVIL_ENV="${HOME}/.anvil.env"
[ -f "$ANVIL_ENV" ] && source "$ANVIL_ENV"

API_URL="${ANVIL_REVIEWER_URL:-https://api.openai.com/v1}"
API_MODEL="${ANVIL_REVIEWER_MODEL:-gpt-4o}"
API_KEY="${ANVIL_REVIEWER_API_KEY:-}"

FILES="$@"
[ -z "$FILES" ] && exit 0

DIFF=$(git diff HEAD -- $FILES 2>/dev/null)
[ -z "$DIFF" ] && DIFF=$(git diff HEAD~1 -- $FILES 2>/dev/null)
[ -z "$DIFF" ] && exit 0

# Combine review prompt with diff, JSON-escaped
COMBINED_CONTENT=$(python3 -c "
import sys,json
prompt = '''Review this code change. Be concise. If correct: say APPROVED. If issues: say REJECTED and list fixes needed.

Diff:
'''
diff = sys.stdin.read()
print(json.dumps(prompt + diff))
" <<< "$DIFF")

RESULT=$(curl -s "${API_URL}/chat/completions" \
    -H "Authorization: Bearer ${API_KEY}" \
    -H "Content-Type: application/json" \
    -d "{
        \"model\": \"${API_MODEL}\",
        \"messages\": [{\"role\": \"user\", \"content\": ${COMBINED_CONTENT}}],
        \"max_tokens\": 1024
    }" 2>/dev/null | python3 -c "
import sys, json
try:
    r = json.load(sys.stdin)
    content = r['choices'][0]['message']['content']
    print(content)
except Exception as e:
    print(f'Review error: {e}', file=sys.stderr)
    sys.exit(1)
" 2>&1)

echo "$RESULT"
if echo "$RESULT" | grep -qi "APPROVED"; then
    exit 0
else
    exit 1
fi
